enum class TabItem(val title: String) { Home("首页"), Work("工时"), Account("记账"), Items("须知") }
enum class WorkFilter(val title: String) { All("全部"), Month("本月"), Today("今日") }
enum class AccountFilter(val title: String) { All("全部"), Expense("支出"), Income("收入") }
enum class TodoFilter(val title: String) { All("全部"), Undone("未完成"), Today("今日"), Done("已完成"), Overdue("过期") }
data class DeleteRequest(val type: String, val id: Long, val title: String, val detail: String)

@OptIn(ExperimentalMaterial3Api::class)
@Composable
fun PersonalBookApp() {
    val context = LocalContext.current
    val store = remember { LocalStore(context) }
    var tab by remember { mutableStateOf(TabItem.Home) }
    var refresh by remember { mutableIntStateOf(0) }
    var dialog by remember { mutableStateOf<String?>(null) }
    var message by remember { mutableStateOf<String?>(null) }
    var importOverwrite by remember { mutableStateOf(false) }
    var editWork by remember { mutableStateOf<WorkRecord?>(null) }
    var editAccount by remember { mutableStateOf<AccountRecord?>(null) }
    var editNote by remember { mutableStateOf<NoteRecord?>(null) }
    var editTodo by remember { mutableStateOf<TodoRecord?>(null) }
    var initialWorkDate by remember { mutableStateOf<String?>(null) }
    var editAdjustment by remember { mutableStateOf<SalaryAdjustment?>(null) }
    var editHoliday by remember { mutableStateOf<HolidayRecord?>(null) }
    var deleteRequest by remember { mutableStateOf<DeleteRequest?>(null) }
    val snackbarHostState = remember { SnackbarHostState() }
    fun reload() { refresh++ }

    val importLauncher = rememberLauncherForActivityResult(ActivityResultContracts.OpenDocument()) { uri ->
        if (uri != null) {
            runCatching {
                val json = context.contentResolver.openInputStream(uri)?.bufferedReader()?.use { it.readText() }
                    ?: error("无法读取所选文件")
                store.importJson(json, importOverwrite)
                reload()
            }.onSuccess { message = "导入完成" }
                .onFailure { message = "导入失败：${it.message}" }
        }
    }

    LaunchedEffect(message) { message?.let { snackbarHostState.showSnackbar(it); message = null } }
    val work = remember(refresh) { store.allWork() }
    val accounts = remember(refresh) { store.allAccounts() }
    val notes = remember(refresh) { store.allNotes() }
    val todos = remember(refresh) { store.allTodos() }
    val salarySettings = remember(refresh) { store.salarySettings() }
    val salaryAdjustments = remember(refresh) { store.allSalaryAdjustments() }
    val holidays = remember(refresh) { store.allHolidays() }

    Scaffold(
        snackbarHost = { SnackbarHost(snackbarHostState) },
        topBar = { TopAppBar(title = { Text(if (tab == TabItem.Home) "小账工时本" else tab.title) }, actions = {
            IconButton(onClick = { runCatching { store.exportToJson(context) }.onSuccess { message = "已导出：${it.absolutePath}" }.onFailure { message = "导出失败：${it.message}" } }) { Icon(Icons.Default.FileUpload, contentDescription = "导出备份") }
            IconButton(onClick = { dialog = "import" }) { Icon(Icons.Default.SettingsBackupRestore, contentDescription = "导入备份") }
        }) },
        bottomBar = { NavigationBar { TabItem.entries.forEach { item -> NavigationBarItem(selected = tab == item, onClick = { tab = item }, icon = { Icon(tabIcon(item), contentDescription = item.title) }, label = { Text(item.title) }) } } },
        floatingActionButton = {
            if (tab != TabItem.Items) {
                FloatingActionButton(onClick = {
                    initialWorkDate = null
                    when (tab) {
                        TabItem.Home -> dialog = "quick"
                        TabItem.Work -> { editWork = null; dialog = "work" }
                        TabItem.Account -> { editAccount = null; dialog = "account" }
                        TabItem.Items -> Unit
                    }
                }) { Icon(Icons.Default.Add, contentDescription = "新建") }
            }
        }
    ) { padding ->
        when (tab) {
            TabItem.Home -> HomeScreen(
                work = work,
                accounts = accounts,
                settings = salarySettings,
                adjustments = salaryAdjustments,
                modifier = Modifier.padding(padding),
                onAction = { key -> editWork = null; editAccount = null; dialog = key }
            )
            TabItem.Work -> WorkScreen(
                records = work,
                settings = salarySettings,
                adjustments = salaryAdjustments,
                holidays = holidays,
                modifier = Modifier.padding(padding),
                onEdit = { initialWorkDate = null; editWork = it; dialog = "work" },
                onDelete = { r -> deleteRequest = DeleteRequest("work", r.id, "删除工时记录？", "${r.date} ${r.startTime}-${r.endTime}") },
                onAddForDate = { date -> initialWorkDate = date; editWork = null; dialog = "work" },
                onSettings = { dialog = "salarySettings" },
                onAddAdjustment = { editAdjustment = null; dialog = "salaryAdjustment" },
                onEditAdjustment = { editAdjustment = it; dialog = "salaryAdjustment" },
                onDeleteAdjustment = { a -> deleteRequest = DeleteRequest("salaryAdjustment", a.id, "删除工资调整项？", "${a.type} ${yuan(a.amount)}") },
                onAddHoliday = { editHoliday = null; dialog = "holiday" },
                onEditHoliday = { editHoliday = it; dialog = "holiday" },
                onDeleteHoliday = { h -> deleteRequest = DeleteRequest("holiday", h.id, "删除节假日？", "${h.date} ${h.name}") }
            )
            TabItem.Account -> AccountScreen(accounts, Modifier.padding(padding), onEdit = { editAccount = it; dialog = "account" }, onDelete = { r -> deleteRequest = DeleteRequest("account", r.id, "删除账目？", "${r.category} · ${yuan(r.amount)}") })
            TabItem.Items -> GuideScreen(Modifier.padding(padding))
        }
    }

    when (dialog) {
        "quick" -> QuickAddDialog(onDismiss = { dialog = null }, onPick = { initialWorkDate = null; editWork = null; editAccount = null; editNote = null; editTodo = null; dialog = it })
        "quickItem" -> QuickItemDialog(onDismiss = { dialog = null }, onPick = { editNote = null; editTodo = null; dialog = it })
        "work" -> WorkDialog(record = editWork, initialDate = initialWorkDate, settings = salarySettings, holidays = holidays, onDismiss = { dialog = null; editWork = null; initialWorkDate = null }, onSave = { store.saveWork(it); reload(); dialog = null; editWork = null; initialWorkDate = null; message = "工时已保存" })
        "salarySettings" -> SalarySettingsDialog(settings = salarySettings, onDismiss = { dialog = null }, onSave = { store.saveSalarySettings(it); reload(); dialog = null; message = "工资设置已保存" })
        "salaryAdjustment" -> SalaryAdjustmentDialog(record = editAdjustment, settings = salarySettings, onDismiss = { dialog = null; editAdjustment = null }, onSave = { store.saveSalaryAdjustment(it); reload(); dialog = null; editAdjustment = null; message = "工资调整项已保存" })
        "holiday" -> HolidayDialog(record = editHoliday, onDismiss = { dialog = null; editHoliday = null }, onSave = { store.saveHoliday(it); reload(); dialog = null; editHoliday = null; message = "节假日已保存" })
        "account" -> AccountDialog(record = editAccount, onDismiss = { dialog = null; editAccount = null }, onSave = { store.saveAccount(it); reload(); dialog = null; editAccount = null; message = "账目已保存" })
        "note" -> NoteDialog(record = editNote, onDismiss = { dialog = null; editNote = null }, onSave = { store.saveNote(it); reload(); dialog = null; editNote = null; message = "笔记已保存" })
        "todo" -> TodoDialog(record = editTodo, onDismiss = { dialog = null; editTodo = null }, onSave = { store.saveTodo(it); reload(); dialog = null; editTodo = null; message = "待办已保存" })
        "import" -> ImportDialog(overwrite = importOverwrite, onOverwriteChange = { importOverwrite = it }, onDismiss = { dialog = null }, onPickFile = { dialog = null; importLauncher.launch(arrayOf("application/json", "text/*", "*/*")) })
    }

    deleteRequest?.let { req -> AlertDialog(onDismissRequest = { deleteRequest = null }, icon = { Icon(Icons.Default.Warning, contentDescription = null) }, title = { Text(req.title) }, text = { Text("确认删除：${req.detail}\n删除后不可直接恢复，建议重要数据先导出备份。") }, confirmButton = { FilledTonalButton(onClick = { when (req.type) { "work" -> store.deleteWork(req.id); "account" -> store.deleteAccount(req.id); "note" -> store.deleteNote(req.id); "todo" -> store.deleteTodo(req.id); "salaryAdjustment" -> store.deleteSalaryAdjustment(req.id); "holiday" -> store.deleteHoliday(req.id) }; reload(); deleteRequest = null; message = "已删除" }) { Text("确认删除") } }, dismissButton = { TextButton(onClick = { deleteRequest = null }) { Text("取消") } }) }
}

private fun tabIcon(item: TabItem) = when (item) { TabItem.Home -> Icons.Default.Dashboard; TabItem.Work -> Icons.Default.AccessTime; TabItem.Account -> Icons.Default.AccountBalanceWallet; TabItem.Items -> Icons.Default.FactCheck }

@Composable
fun HomeScreen(work: List<WorkRecord>, accounts: List<AccountRecord>, settings: SalarySettings, adjustments: List<SalaryAdjustment>, modifier: Modifier = Modifier, onAction: (String) -> Unit) {
val today = dayText(); val month = monthText()
val todayWork = remember(work, today) { work.filter { it.date == today } }
val monthWork = remember(work, month) { work.filter { it.date.startsWith(month) } }
val monthAccounts = remember(accounts, month) { accounts.filter { it.date.startsWith(month) } }
val totalIncome = remember(accounts) { accounts.filter { it.type == TYPE_INCOME }.sumOf { it.amount } }
val totalExpense = remember(accounts) { accounts.filter { it.type == TYPE_EXPENSE }.sumOf { it.amount } }
val monthIncome = remember(monthAccounts) { monthAccounts.filter { it.type == TYPE_INCOME }.sumOf { it.amount } }
val monthExpense = remember(monthAccounts) { monthAccounts.filter { it.type == TYPE_EXPENSE }.sumOf { it.amount } }
val todayExpense = remember(accounts, today) { accounts.filter { it.date == today && it.type == TYPE_EXPENSE }.sumOf { it.amount } }
val totalBalance = totalIncome - totalExpense
val salaryPeriod = remember(settings, today) { salaryPeriodOf(today, settings) }
val salarySummary = remember(work, settings, adjustments, salaryPeriod) { calculateSalary(work, settings, adjustments, salaryPeriod) }
LazyColumn(modifier.fillMaxSize(), state = rememberLazyListState(), contentPadding = screenPadding(), verticalArrangement = Arrangement.spacedBy(12.dp)) {
item(key = "home-hero") { HomeHeroCard(totalBalance, totalIncome, totalExpense, todayWork.sumOf { it.hours }, todayWork.sumOf { it.wage }, todayExpense, 0) }
item(key = "home-stats") { Row(Modifier.fillMaxWidth(), horizontalArrangement = Arrangement.spacedBy(10.dp)) { HomeSmallCard("本月工时", "${fmt(monthWork.sumOf { it.hours })}h", "工资 ${yuan(monthWork.sumOf { it.wage })}", Modifier.weight(1f)); HomeSmallCard("本月收支", yuan(monthIncome - monthExpense), "收 ${yuan(monthIncome)} · 支 ${yuan(monthExpense)}", Modifier.weight(1f)) } }
item(key = "salary-section") { SectionTitle("工资明细") }
item(key = "home-salary-period") { HomeSalaryPeriodCard(salaryPeriod, salarySummary, onAction) }
item(key = "home-salary-detail") { SalaryDetailCard(salarySummary) }
}
}


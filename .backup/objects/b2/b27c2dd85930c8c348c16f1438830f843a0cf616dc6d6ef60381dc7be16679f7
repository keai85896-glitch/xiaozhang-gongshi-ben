@Composable fun AccountScreen(records: List<AccountRecord>, modifier: Modifier, onEdit: (AccountRecord) -> Unit, onDelete: (AccountRecord) -> Unit) {
    var filter by remember { mutableStateOf(AccountFilter.All) }
    val month = monthText()
    val monthRecords = remember(records, month) { records.filter { it.dateTime.startsWith(month) } }
    val income = remember(monthRecords) { monthRecords.filter { it.type == TYPE_INCOME }.sumOf { it.amount } }
    val expense = remember(monthRecords) { monthRecords.filter { it.type == TYPE_EXPENSE }.sumOf { it.amount } }
    val allExpenseCount = remember(records) { records.count { it.type == TYPE_EXPENSE } }
    val allIncomeCount = remember(records) { records.count { it.type == TYPE_INCOME } }
    val shown = remember(records, filter) { records.filter { when (filter) { AccountFilter.All -> true; AccountFilter.Expense -> it.type == TYPE_EXPENSE; AccountFilter.Income -> it.type == TYPE_INCOME } } }
    val grouped = remember(shown) { shown.groupBy { it.dateTime.take(10) } }
    val topExpense = remember(monthRecords) { monthRecords.filter { it.type == TYPE_EXPENSE }.groupBy { it.category }.mapValues { it.value.sumOf { r -> r.amount } }.maxByOrNull { it.value } }
    val topIncome = remember(monthRecords) { monthRecords.filter { it.type == TYPE_INCOME }.groupBy { it.category }.mapValues { it.value.sumOf { r -> r.amount } }.maxByOrNull { it.value } }
    LazyColumn(modifier.fillMaxSize(), state = rememberLazyListState(), contentPadding = screenPadding(), verticalArrangement = Arrangement.spacedBy(8.dp)) {
        item(key = "account-overview") { AccountOverviewCard(income, expense, monthRecords.size) }
        item(key = "account-insight") { AccountInsightCard(topExpense?.key, topExpense?.value ?: 0.0, topIncome?.key, topIncome?.value ?: 0.0, monthRecords.size) }
        item(key = "account-filter") { FilterRow(AccountFilter.entries, filter, { f -> when (f) { AccountFilter.All -> "全部 ${records.size}"; AccountFilter.Expense -> "支出 $allExpenseCount"; AccountFilter.Income -> "收入 $allIncomeCount" } }) { filter = it } }
        if (shown.isEmpty()) item(key = "empty-account") { EmptyCard("没有匹配的账目", "可切换筛选或点击右下角记一笔") }
        else grouped.forEach { (date, list) ->
            item(key = "account-day-$date") { AccountDayHeader(date, list) }
            items(list, key = { "account-${it.id}" }) { AccountRow(it, onEdit, onDelete) }
        }
    }
}

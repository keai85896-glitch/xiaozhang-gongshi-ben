@Composable
fun WorkScreen(
    records: List<WorkRecord>,
    settings: SalarySettings,
    adjustments: List<SalaryAdjustment>,
    holidays: List<HolidayRecord>,
    modifier: Modifier,
    onEdit: (WorkRecord) -> Unit,
    onDelete: (WorkRecord) -> Unit,
    onAddForDate: (String) -> Unit,
    onSettings: () -> Unit,
    onAddAdjustment: () -> Unit,
    onEditAdjustment: (SalaryAdjustment) -> Unit,
    onDeleteAdjustment: (SalaryAdjustment) -> Unit,
    onAddHoliday: () -> Unit,
    onEditHoliday: (HolidayRecord) -> Unit,
    onDeleteHoliday: (HolidayRecord) -> Unit
) {
    var filter by remember { mutableStateOf(WorkFilter.Month) }
    var calendarMonth by remember { mutableStateOf(monthText()) }
    var showDetail by remember { mutableStateOf(false) }
    val today = dayText()
    val currentMonth = monthText()
    val period = remember(settings, today) { salaryPeriodOf(today, settings) }
    val summary = remember(records, settings, adjustments, period) { calculateSalary(records, settings, adjustments, period) }
    val periodRecords = remember(records, period) { records.filter { it.date in period.start..period.end } }
    val missed = remember(records, currentMonth) { missedWorkDates(records, currentMonth) }
    val todayRecords = remember(records, today) { records.filter { it.date == today } }
    val shown = remember(records, filter, period, today) { records.filter { r -> when (filter) { WorkFilter.All -> true; WorkFilter.Month -> r.date in period.start..period.end; WorkFilter.Today -> r.date == today } } }
    val grouped = remember(shown) { shown.groupBy { it.date } }
    LazyColumn(modifier.fillMaxSize(), state = rememberLazyListState(), contentPadding = screenPadding(), verticalArrangement = Arrangement.spacedBy(8.dp)) {
        item(key = "salary-overview") { SalaryOverviewCard(summary, period, missed.size, todayRecords.sumOf { it.hours }, periodRecords.map { it.date }.distinct().size, onSettings) }
        item(key = "work-switch") { CompactWorkToolbar(showDetail, { showDetail = !showDetail }, onAddAdjustment, onAddHoliday) }
        if (showDetail) {
                        item(key = "overtime") { OvertimeStatsCard(summary) }
            item(key = "shift") { ShiftStatsCard(summary) }
            item(key = "manage") { SalaryManageCard(adjustments, holidays, period, onAddAdjustment, onEditAdjustment, onDeleteAdjustment, onAddHoliday, onEditHoliday, onDeleteHoliday) }
            item(key = "calendar") { WorkCalendarCard(records = records, holidays = holidays, month = calendarMonth, onMonthChange = { calendarMonth = it }, onDateClick = { date -> records.filter { it.date == date }.maxByOrNull { it.id }?.let(onEdit) ?: onAddForDate(date) }) }
        }
        item(key = "filter") { FilterRow(WorkFilter.entries, filter, { f -> when (f) { WorkFilter.All -> "全部 ${records.size}"; WorkFilter.Month -> "本周期 ${periodRecords.size}"; WorkFilter.Today -> "今日 ${todayRecords.size}" } }) { filter = it } }
        if (shown.isEmpty()) item(key = "empty-work") { EmptyCard("没有匹配的工时记录", "点右下角新增，或展开详情后点击日历补录") } else grouped.forEach { (date, list) ->
            item(key = "work-day-$date") { WorkDayHeader(date, list) }
            items(list, key = { "work-${it.id}" }) { r -> WorkRow(r, onEdit, onDelete) }
        }
    }
}


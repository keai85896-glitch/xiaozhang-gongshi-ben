@Composable fun AccountDialog(record: AccountRecord?, onDismiss: () -> Unit, onSave: (AccountRecord) -> Unit) { var type by remember(record?.id) { mutableStateOf(record?.type ?: TYPE_EXPENSE) }; var amount by remember(record?.id) { mutableStateOf(record?.amount?.takeIf { it > 0 }?.let { String.format(Locale.CHINA, "%.2f", it) } ?: "") }; var cat by remember(record?.id) { mutableStateOf(record?.category ?: "餐饮") }; var dateTime by remember(record?.id) { mutableStateOf(record?.dateTime ?: dateTimeText()) }; var note by remember(record?.id) { mutableStateOf(record?.note ?: "") }; var error by remember { mutableStateOf<String?>(null) }; FormDialog(if (record == null) "记一笔" else "编辑账目", error, onDismiss, { val money = amount.toDoubleOrNull(); error = when { money == null || money <= 0 -> "金额不能为空，且必须大于 0"; cat.isBlank() -> "分类不能为空"; !validDateTime(dateTime) -> "日期时间格式错误，应为 yyyy-MM-dd HH:mm"; else -> null }; if (error == null) onSave((record ?: AccountRecord()).copy(type = type, amount = money!!, category = cat.trim(), dateTime = dateTime, note = note)) }) { Row { FilterChip(selected = type == TYPE_EXPENSE, onClick = { type = TYPE_EXPENSE }, label = { Text("支出") }); Spacer(Modifier.width(8.dp)); FilterChip(selected = type == TYPE_INCOME, onClick = { type = TYPE_INCOME }, label = { Text("收入") }) }; Field("金额", amount, true) { amount = it }; Field("分类", cat) { cat = it }; Field("日期时间 yyyy-MM-dd HH:mm", dateTime) { dateTime = it }; Field("备注", note) { note = it } } }
@Composable fun NoteDialog(record: NoteRecord?, onDismiss: () -> Unit, onSave: (NoteRecord) -> Unit) { var title by remember(record?.id) { mutableStateOf(record?.title ?: "") }; var content by remember(record?.id) { mutableStateOf(record?.content ?: "") }; var tags by remember(record?.id) { mutableStateOf(record?.tags ?: "") }; var pinned by remember(record?.id) { mutableStateOf(record?.pinned ?: false) }; var error by remember { mutableStateOf<String?>(null) }; FormDialog(if (record == null) "新建笔记" else "编辑笔记", error, onDismiss, { error = if (title.isBlank() && content.isBlank()) "标题和内容不能同时为空" else null; if (error == null) onSave((record ?: NoteRecord()).copy(title = title.trim(), content = content, tags = tags.trim(), pinned = pinned)) }) { Field("标题", title) { title = it }; Field("内容", content, minLines = 4) { content = it }; Field("标签", tags) { tags = it }; Row(verticalAlignment = Alignment.CenterVertically) { Switch(checked = pinned, onCheckedChange = { pinned = it }); Text("置顶") } } }
@Composable fun TodoDialog(record: TodoRecord?, onDismiss: () -> Unit, onSave: (TodoRecord) -> Unit) { var title by remember(record?.id) { mutableStateOf(record?.title ?: "") }; var desc by remember(record?.id) { mutableStateOf(record?.description ?: "") }; var due by remember(record?.id) { mutableStateOf(record?.dueDate ?: dayText()) }; var pri by remember(record?.id) { mutableStateOf(record?.priority ?: "中") }; var error by remember { mutableStateOf<String?>(null) }; var pickingDate by remember { mutableStateOf(false) }; FormDialog(if (record == null) "新增待办" else "编辑待办", error, onDismiss, { error = when { title.isBlank() -> "待办标题不能为空"; !validDate(due) -> "请选择正确截止日期"; pri !in listOf("高", "中", "低") -> "优先级只能填写：高 / 中 / 低"; else -> null }; if (error == null) onSave((record ?: TodoRecord()).copy(title = title.trim(), description = desc, dueDate = due, priority = pri)) }) { Field("标题", title) { title = it }; Field("描述", desc) { desc = it }; DateSelectField("截止日期", due) { pickingDate = true }; ChoiceRow("优先级", listOf("高", "中", "低"), pri) { pri = it } }; if (pickingDate) DatePickerDialogBox(title = "选择截止日期", initial = due, onDismiss = { pickingDate = false }, onConfirm = { due = it; pickingDate = false }) }

@Composable fun ImportDialog(overwrite: Boolean, onOverwriteChange: (Boolean) -> Unit, onDismiss: () -> Unit, onPickFile: () -> Unit) { AlertDialog(onDismissRequest = onDismiss, title = { Text("导入备份") }, text = { Column(verticalArrangement = Arrangement.spacedBy(10.dp)) { Text("请选择之前导出的 JSON 备份文件。", color = MaterialTheme.colorScheme.onSurfaceVariant); Row(verticalAlignment = Alignment.CenterVertically) { Switch(checked = overwrite, onCheckedChange = onOverwriteChange); Text("覆盖现有数据") } } }, confirmButton = { FilledTonalButton(onClick = onPickFile) { Text("选择文件") } }, dismissButton = { TextButton(onClick = onDismiss) { Text("取消") } }) }
@Composable fun FormDialog(title: String, error: String?, onDismiss: () -> Unit, onConfirm: () -> Unit, content: @Composable ColumnScope.() -> Unit) { AlertDialog(onDismissRequest = onDismiss, title = { Text(title) }, text = { Column(Modifier.verticalScroll(rememberScrollState()), verticalArrangement = Arrangement.spacedBy(8.dp)) { if (error != null) Text(error, color = MaterialTheme.colorScheme.error, style = MaterialTheme.typography.bodyMedium); content() } }, confirmButton = { FilledTonalButton(onClick = onConfirm) { Text("保存") } }, dismissButton = { TextButton(onClick = onDismiss) { Text("取消") } }) }
@Composable fun Field(label: String, value: String, number: Boolean = false, minLines: Int = 1, onChange: (String) -> Unit) { OutlinedTextField(value = value, onValueChange = onChange, label = { Text(label) }, modifier = Modifier.fillMaxWidth(), minLines = minLines, keyboardOptions = KeyboardOptions(keyboardType = if (number) KeyboardType.Decimal else KeyboardType.Text), singleLine = minLines == 1) }
fun fmt(v: Double) = String.format(Locale.CHINA, "%.1f", v)

private fun monthTitle(month: String): String = runCatching { SimpleDateFormat("yyyy年 MM月", Locale.CHINA).format(SimpleDateFormat("yyyy-MM", Locale.CHINA).parse(month)!!) }.getOrDefault(month)
private fun shiftMonth(month: String, offset: Int): String { val d = SimpleDateFormat("yyyy-MM", Locale.CHINA).parse(month) ?: return month; val c = Calendar.getInstance(Locale.CHINA).apply { time = d; add(Calendar.MONTH, offset) }; return SimpleDateFormat("yyyy-MM", Locale.CHINA).format(c.time) }
private fun displayMillis(ms: Long): String = SimpleDateFormat("yyyy年 MM月 dd日 HH:mm", Locale.CHINA).format(Date(ms))
private fun firstWeekdayOffset(month: String): Int { val c = Calendar.getInstance(Locale.CHINA); val d = SimpleDateFormat("yyyy-MM-dd", Locale.CHINA).parse("$month-01") ?: return 0; c.time = d; return (c.get(Calendar.DAY_OF_WEEK) + 5) % 7 }
private fun monthDays(month: String): List<String> { val c = Calendar.getInstance(Locale.CHINA); val d = SimpleDateFormat("yyyy-MM-dd", Locale.CHINA).parse("$month-01") ?: return emptyList(); c.time = d; val max = c.getActualMaximum(Calendar.DAY_OF_MONTH); return (1..max).map { String.format(Locale.CHINA, "%s-%02d", month, it) } }
private fun isSunday(date: String): Boolean { val d = parseDate(date) ?: return false; return Calendar.getInstance(Locale.CHINA).apply { time = d }.get(Calendar.DAY_OF_WEEK) == Calendar.SUNDAY }
private fun isWeekday(date: String): Boolean = !isSunday(date)
private fun missedWorkDates(records: List<WorkRecord>, month: String): List<String> {
    val today = parseDate(dayText()) ?: return emptyList(); val first = parseDate("$month-01") ?: return emptyList(); val have = records.filter { it.date.startsWith(month) }.map { it.date }.toSet()
    val c = Calendar.getInstance(Locale.CHINA).apply { time = first }; val end = Calendar.getInstance(Locale.CHINA).apply { time = today }
    val result = mutableListOf<String>(); val fmt = SimpleDateFormat("yyyy-MM-dd", Locale.CHINA)
    while (!c.after(end) && fmt.format(c.time).startsWith(month)) { val d = fmt.format(c.time); if (isWeekday(d) && d !in have) result += d; c.add(Calendar.DAY_OF_MONTH, 1) }
    return result
}
private fun shortDisplayDate(date: String): String { val d = parseDate(date) ?: return date; return SimpleDateFormat("MM月dd日", Locale.CHINA).format(d) + " " + weekText(d) }
private fun parseDate(text: String): Date? = runCatching { SimpleDateFormat("yyyy-MM-dd", Locale.CHINA).apply { isLenient = false }.parse(text) }.getOrNull()
private fun weekText(date: Date): String { val c = Calendar.getInstance(Locale.CHINA).apply { time = date }; return when (c.get(Calendar.DAY_OF_WEEK)) { Calendar.SUNDAY -> "周日"; Calendar.MONDAY -> "周一"; Calendar.TUESDAY -> "周二"; Calendar.WEDNESDAY -> "周三"; Calendar.THURSDAY -> "周四"; Calendar.FRIDAY -> "周五"; Calendar.SATURDAY -> "周六"; else -> "" } }
private fun displayDate(text: String): String { val d = parseDate(text) ?: return text; return SimpleDateFormat("yyyy年 MM月 dd日", Locale.CHINA).format(d) + " " + weekText(d) }
private fun displayDateTime(text: String): String { val parts = text.split(" ", limit = 2); val date = displayDate(parts.getOrNull(0) ?: text); val time = parts.getOrNull(1); return if (time.isNullOrBlank()) date else "$date $time" }
private fun dateToMillis(text: String): Long? { val d = parseDate(text) ?: return null; return Calendar.getInstance(Locale.CHINA).apply { time = d; set(Calendar.HOUR_OF_DAY, 12); set(Calendar.MINUTE, 0); set(Calendar.SECOND, 0); set(Calendar.MILLISECOND, 0) }.timeInMillis }
private fun millisToDate(ms: Long): String = SimpleDateFormat("yyyy-MM-dd", Locale.CHINA).format(Date(ms))
private fun validDate(text: String) = validByPattern(text, "yyyy-MM-dd")
private fun validTime(text: String) = validByPattern(text, "HH:mm")
private fun validDateTime(text: String) = validByPattern(text, "yyyy-MM-dd HH:mm")
private fun validByPattern(text: String, pattern: String): Boolean = runCatching { SimpleDateFormat(pattern, Locale.CHINA).apply { isLenient = false }.parse(text); text.length == pattern.length }.getOrDefault(false)


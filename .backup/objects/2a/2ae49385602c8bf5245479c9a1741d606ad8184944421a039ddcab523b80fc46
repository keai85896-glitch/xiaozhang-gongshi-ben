@Composable fun Field(label: String, value: String, number: Boolean = false, minLines: Int = 1, onChange: (String) -> Unit) { OutlinedTextField(value = value, onValueChange = onChange, label = { Text(label) }, modifier = Modifier.fillMaxWidth(), minLines = minLines, keyboardOptions = KeyboardOptions(keyboardType = if (number) KeyboardType.Decimal else KeyboardType.Text), singleLine = minLines == 1) }
fun fmt(v: Double) = String.format(Locale.CHINA, "%.1f", v)

private fun monthTitle(month: String): String = runCatching { SimpleDateFormat("yyyy年 MM月", Locale.CHINA).format(SimpleDateFormat("yyyy-MM", Locale.CHINA).parse(month)!!) }.getOrDefault(month)
private fun firstWeekdayOffset(month: String): Int { val c = Calendar.getInstance(Locale.CHINA); val d = SimpleDateFormat("yyyy-MM-dd", Locale.CHINA).parse("$month-01") ?: return 0; c.time = d; return (c.get(Calendar.DAY_OF_WEEK) + 5) % 7 }
private fun monthDays(month: String): List<String> { val c = Calendar.getInstance(Locale.CHINA); val d = SimpleDateFormat("yyyy-MM-dd", Locale.CHINA).parse("$month-01") ?: return emptyList(); c.time = d; val max = c.getActualMaximum(Calendar.DAY_OF_MONTH); return (1..max).map { String.format(Locale.CHINA, "%s-%02d", month, it) } }
private fun isWeekday(date: String): Boolean { val d = parseDate(date) ?: return false; val day = Calendar.getInstance(Locale.CHINA).apply { time = d }.get(Calendar.DAY_OF_WEEK); return day != Calendar.SUNDAY }
private fun missedWorkDates(records: List<WorkRecord>, month: String): List<String> {
    val today = parseDate(dayText()) ?: return emptyList(); val first = parseDate("$month-01") ?: return emptyList(); val have = records.filter { it.date.startsWith(month) }.map { it.date }.toSet()
    val c = Calendar.getInstance(Locale.CHINA).apply { time = first }; val end = Calendar.getInstance(Locale.CHINA).apply { time = today }
    val result = mutableListOf<String>(); val fmt = SimpleDateFormat("yyyy-MM-dd", Locale.CHINA)
    while (!c.after(end) && fmt.format(c.time).startsWith(month)) { val d = fmt.format(c.time); if (isWeekday(d) && d !in have) result += d; c.add(Calendar.DAY_OF_MONTH, 1) }
    return result
}
private fun shortDisplayDate(date: String): String { val d = parseDate(date) ?: return date; return SimpleDateFormat("MM月dd日", Locale.CHINA).format(d) + " " + weekText(d) }
private fun parseDate(text: String): Date? = runCatching { SimpleDateFormat("yyyy-MM-dd", Locale.CHINA).apply { isLenient = false }.parse(text) }.getOrNull()
private fun weekText(date: Date): String { val c = Calendar.getInstance(Locale.CHINA).apply { time = date }; return when (c.get(Calendar.DAY_OF_WEEK)) { Calendar.SUNDAY -> "周日"; Calendar.MONDAY -> "周一"; Calendar.TUESDAY -> "周二"; Calendar.WEDNESDAY -> "周三"; Calendar.THURSDAY -> "周四"; Calendar.FRIDAY -> "周五"; Calendar.SATURDAY -> "周六"; else -> "" } }
private fun displayDate(text: String): String { val d = parseDate(text) ?: return text; return SimpleDateFormat("yyyy年 MM月 dd日", Locale.CHINA).format(d) + " " + weekText(d) }
private fun displayDateTime(text: String): String { val parts = text.split(" ", limit = 2); val date = displayDate(parts.getOrNull(0) ?: text); val time = parts.getOrNull(1); return if (time.isNullOrBlank()) date else "$date $time" }
private fun dateToMillis(text: String): Long? { val d = parseDate(text) ?: return null; return Calendar.getInstance(Locale.CHINA).apply { time = d; set(Calendar.HOUR_OF_DAY, 12); set(Calendar.MINUTE, 0); set(Calendar.SECOND, 0); set(Calendar.MILLISECOND, 0) }.timeInMillis }
private fun millisToDate(ms: Long): String = SimpleDateFormat("yyyy-MM-dd", Locale.CHINA).format(Date(ms))
private fun validDate(text: String) = validByPattern(text, "yyyy-MM-dd")
private fun validTime(text: String) = validByPattern(text, "HH:mm")
private fun validDateTime(text: String) = validByPattern(text, "yyyy-MM-dd HH:mm")
private fun validByPattern(text: String, pattern: String): Boolean = runCatching { SimpleDateFormat(pattern, Locale.CHINA).apply { isLenient = false }.parse(text); text.length == pattern.length }.getOrDefault(false)


@Composable
fun WorkScreen(records: List<WorkRecord>, modifier: Modifier, onEdit: (WorkRecord) -> Unit, onDelete: (WorkRecord) -> Unit, onAddForDate: (String) -> Unit) {
    var filter by remember { mutableStateOf(WorkFilter.Month) }; var selectedDate by remember { mutableStateOf<String?>(null) }
    val today = dayText(); val month = monthText(); val m = records.filter { it.date.startsWith(month) }; val missed = missedWorkDates(records, month)
    val todayRecords = records.filter { it.date == today }
    val shown = records.filter { r -> selectedDate?.let { r.date == it } ?: when (filter) { WorkFilter.All -> true; WorkFilter.Month -> r.date.startsWith(month); WorkFilter.Today -> r.date == today } }
    val grouped = shown.groupBy { it.date }
    LazyColumn(modifier.fillMaxSize(), contentPadding = screenPadding(), verticalArrangement = Arrangement.spacedBy(10.dp)) {
        item { WorkOverviewCard(m.sumOf { it.hours }, m.sumOf { it.wage }, m.map { it.date }.distinct().size, todayRecords.sumOf { it.hours }, missed.size) }
        item { WorkCalendarCard(records, month, selectedDate) { selectedDate = if (selectedDate == it) null else it } }
        item { MissedWorkCard(missed, onAddForDate) }
        item { FilterRow(WorkFilter.entries, filter, { f -> when (f) { WorkFilter.All -> "全部 ${records.size}"; WorkFilter.Month -> "本月 ${m.size}"; WorkFilter.Today -> "今日 ${todayRecords.size}" } }) { selectedDate = null; filter = it } }
        selectedDate?.let { item { AssistChip(onClick = { selectedDate = null }, label = { Text("当前查看：${displayDate(it)}，点击清除") }, leadingIcon = { Icon(Icons.Default.Close, contentDescription = null) }) } }
        if (shown.isEmpty()) item { EmptyCard("没有匹配的工时记录", "可切换筛选、点击日历日期或右下角新建") } else grouped.forEach { (date, list) -> item(key = "work-day-$date") { WorkDayHeader(date, list) }; items(list, key = { it.id }) { r -> WorkRow(r, onEdit, onDelete) } }
    }
}

@Composable fun WorkOverviewCard(monthHours: Double, monthWage: Double, workDays: Int, todayHours: Double, missedCount: Int) { ElevatedCard(Modifier.fillMaxWidth()) { Column(Modifier.padding(16.dp), verticalArrangement = Arrangement.spacedBy(12.dp)) { Row(Modifier.fillMaxWidth(), horizontalArrangement = Arrangement.SpaceBetween, verticalAlignment = Alignment.Top) { Column { Text("本月工时", style = MaterialTheme.typography.titleMedium, fontWeight = FontWeight.Bold); Text("已记录 $workDays 天 · 日均 ${fmt(if (workDays == 0) 0.0 else monthHours / workDays)}h", style = MaterialTheme.typography.labelMedium, color = MaterialTheme.colorScheme.onSurfaceVariant) }; Text("${fmt(monthHours)}h", style = MaterialTheme.typography.headlineSmall, fontWeight = FontWeight.Bold, color = MaterialTheme.colorScheme.primary) }; Row(Modifier.fillMaxWidth(), horizontalArrangement = Arrangement.spacedBy(10.dp)) { AccountStatPill("预估工资", yuan(monthWage), MaterialTheme.colorScheme.primaryContainer, Modifier.weight(1f)); AccountStatPill("今日工时", "${fmt(todayHours)}h", MaterialTheme.colorScheme.tertiaryContainer, Modifier.weight(1f)); AccountStatPill("漏记", "${missedCount}天", if (missedCount > 0) MaterialTheme.colorScheme.errorContainer else MaterialTheme.colorScheme.secondaryContainer, Modifier.weight(1f)) } } } }
@Composable fun WorkDayHeader(date: String, list: List<WorkRecord>) { val h = list.sumOf { it.hours }; val w = list.sumOf { it.wage }; Row(Modifier.fillMaxWidth().padding(top = 4.dp), horizontalArrangement = Arrangement.SpaceBetween, verticalAlignment = Alignment.CenterVertically) { Text(displayDate(date), style = MaterialTheme.typography.titleSmall, fontWeight = FontWeight.Bold); Text("${fmt(h)}h · ${yuan(w)}", style = MaterialTheme.typography.labelMedium, color = MaterialTheme.colorScheme.onSurfaceVariant) } }

@Composable fun WorkCalendarCard(records: List<WorkRecord>, month: String, selectedDate: String?, onSelectDate: (String) -> Unit) {
    val dates = monthDays(month)
    val monthRecords = records.filter { it.date.startsWith(month) }
    val recordDates = monthRecords.map { it.date }.toSet()
    val workHoursByDate = monthRecords.groupBy { it.date }.mapValues { entry -> entry.value.sumOf { it.hours } }
    val missedDates = missedWorkDates(records, month).toSet()
    val today = dayText()
    val blanks = firstWeekdayOffset(month)
    val baseCells = List(blanks) { "" } + dates
    val cells = (baseCells + List((42 - baseCells.size).coerceAtLeast(0)) { "" }).chunked(7)
    ElevatedCard(Modifier.fillMaxWidth()) {
        Column(Modifier.padding(16.dp), verticalArrangement = Arrangement.spacedBy(12.dp)) {
            Row(Modifier.fillMaxWidth(), horizontalArrangement = Arrangement.SpaceBetween, verticalAlignment = Alignment.CenterVertically) {
                Column(Modifier.weight(1f)) {
                    Text(monthTitle(month), style = MaterialTheme.typography.titleMedium, fontWeight = FontWeight.Bold)
                    Text("记录 ${recordDates.size} 天 · 漏记 ${missedDates.size} 天 · 点击日期筛选", style = MaterialTheme.typography.labelMedium, color = MaterialTheme.colorScheme.onSurfaceVariant)
                }
                if (selectedDate != null) AssistChip(onClick = { onSelectDate(selectedDate) }, label = { Text("清除") }, leadingIcon = { Icon(Icons.Default.Close, contentDescription = null) })
            }
            Row(Modifier.fillMaxWidth().padding(top = 2.dp)) {
                listOf("一", "二", "三", "四", "五", "六", "日").forEachIndexed { index, title ->
                    Text(title, modifier = Modifier.weight(1f), textAlign = TextAlign.Center, style = MaterialTheme.typography.labelMedium, fontWeight = FontWeight.SemiBold, color = if (index == 6) MaterialTheme.colorScheme.outline else if (index == 5) MaterialTheme.colorScheme.error else MaterialTheme.colorScheme.onSurfaceVariant)
                }
            }
            Column(verticalArrangement = Arrangement.spacedBy(6.dp)) {
                cells.forEach { week ->
                    Row(Modifier.fillMaxWidth(), horizontalArrangement = Arrangement.spacedBy(6.dp)) {
                        week.forEach { d ->
                            if (d.isBlank()) CalendarBlankCell(Modifier.weight(1f)) else CalendarDayCell(
                                date = d,
                                hours = workHoursByDate[d] ?: 0.0,
                                isToday = d == today,
                                selected = d == selectedDate,
                                isMissed = d in missedDates,
                                isRestDay = isSunday(d),
                                onClick = { onSelectDate(d) },
                                modifier = Modifier.weight(1f)
                            )
                        }
                    }
                }
            }
            Column(verticalArrangement = Arrangement.spacedBy(6.dp)) {
                Row(horizontalArrangement = Arrangement.spacedBy(12.dp), verticalAlignment = Alignment.CenterVertically) { LegendDot(MaterialTheme.colorScheme.primaryContainer, "有记录"); LegendDot(MaterialTheme.colorScheme.errorContainer, "漏记"); LegendDot(MaterialTheme.colorScheme.tertiaryContainer, "今天") }
                Row(horizontalArrangement = Arrangement.spacedBy(12.dp), verticalAlignment = Alignment.CenterVertically) { LegendDot(MaterialTheme.colorScheme.primary, "已选中"); LegendDot(MaterialTheme.colorScheme.surfaceVariant, "周日休息") }
            }
        }
    }
}
@Composable fun CalendarBlankCell(modifier: Modifier = Modifier) { Surface(modifier.height(50.dp), shape = MaterialTheme.shapes.medium, color = MaterialTheme.colorScheme.surfaceVariant.copy(alpha = 0.28f)) {} }
@Composable fun LegendDot(color: androidx.compose.ui.graphics.Color, text: String) { Row(verticalAlignment = Alignment.CenterVertically, horizontalArrangement = Arrangement.spacedBy(4.dp)) { Surface(shape = MaterialTheme.shapes.small, color = color, modifier = Modifier.size(10.dp)) {}; Text(text, style = MaterialTheme.typography.labelSmall, color = MaterialTheme.colorScheme.onSurfaceVariant) } }
@Composable fun CalendarDayCell(date: String, hours: Double, isToday: Boolean, selected: Boolean, isMissed: Boolean, isRestDay: Boolean, onClick: () -> Unit, modifier: Modifier = Modifier) {
    val day = date.takeLast(2).trimStart('0')
    val hasRecord = hours > 0.0
    val bg = when { selected -> MaterialTheme.colorScheme.primary; isMissed -> MaterialTheme.colorScheme.errorContainer; hasRecord -> MaterialTheme.colorScheme.primaryContainer; isToday -> MaterialTheme.colorScheme.tertiaryContainer; isRestDay -> MaterialTheme.colorScheme.surfaceVariant.copy(alpha = 0.55f); else -> MaterialTheme.colorScheme.surface }
    val fg = when { selected -> MaterialTheme.colorScheme.onPrimary; isMissed -> MaterialTheme.colorScheme.onErrorContainer; else -> MaterialTheme.colorScheme.onSurface }
    val border = if (isToday && !selected) BorderStroke(1.5.dp, MaterialTheme.colorScheme.tertiary) else null
    Surface(onClick = onClick, modifier = modifier.height(50.dp), shape = MaterialTheme.shapes.medium, color = bg, tonalElevation = if (hasRecord || selected || isToday || isMissed) 2.dp else 0.dp, border = border) {
        Box(Modifier.fillMaxSize().padding(3.dp)) {
            Column(Modifier.align(Alignment.Center), horizontalAlignment = Alignment.CenterHorizontally, verticalArrangement = Arrangement.Center) {
                Text(day, color = fg, style = MaterialTheme.typography.bodyMedium, fontWeight = if (hasRecord || isToday || selected || isMissed) FontWeight.Bold else FontWeight.Normal)
                Text(when { hasRecord -> "${fmt(hours)}h"; isMissed -> "漏"; isToday -> "今"; isRestDay -> "休"; else -> "" }, color = fg.copy(alpha = 0.82f), style = MaterialTheme.typography.labelSmall, maxLines = 1)
            }
            if (hasRecord && !selected) Surface(shape = MaterialTheme.shapes.small, color = MaterialTheme.colorScheme.primary, modifier = Modifier.align(Alignment.TopEnd).size(6.dp)) {}
        }
    }
}

@Composable fun AccountScreen(records: List<AccountRecord>, modifier: Modifier, onEdit: (AccountRecord) -> Unit, onDelete: (AccountRecord) -> Unit) {
    var filter by remember { mutableStateOf(AccountFilter.All) }
    val month = monthText()
    val monthRecords = records.filter { it.dateTime.startsWith(month) }
    val income = monthRecords.filter { it.type == TYPE_INCOME }.sumOf { it.amount }
    val expense = monthRecords.filter { it.type == TYPE_EXPENSE }.sumOf { it.amount }
    val shown = records.filter { when (filter) { AccountFilter.All -> true; AccountFilter.Expense -> it.type == TYPE_EXPENSE; AccountFilter.Income -> it.type == TYPE_INCOME } }
    val grouped = shown.groupBy { it.dateTime.take(10) }
    LazyColumn(modifier.fillMaxSize(), contentPadding = screenPadding(), verticalArrangement = Arrangement.spacedBy(10.dp)) {
        item { AccountOverviewCard(income, expense, monthRecords.size) }
        item { AccountQuickStats(monthRecords) }
        item { FilterRow(AccountFilter.entries, filter, { f -> when (f) { AccountFilter.All -> "全部 ${records.size}"; AccountFilter.Expense -> "支出 ${records.count { it.type == TYPE_EXPENSE }}"; AccountFilter.Income -> "收入 ${records.count { it.type == TYPE_INCOME }}" } }) { filter = it } }
        if (shown.isEmpty()) item { EmptyCard("没有匹配的账目", "可切换筛选或点击右下角记一笔") }
        else grouped.forEach { (date, list) ->
            item(key = "account-day-$date") { AccountDayHeader(date, list) }
            items(list, key = { it.id }) { AccountRow(it, onEdit, onDelete) }
        }
    }
}
